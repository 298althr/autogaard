# AutoGaard Production Git Policy
# ONLY core application code is allowed on GitHub.

# 1. Ignore everything by default
/*

# 2. Allow specific project files and core directories
!/client/
!/server/
!/package.json
!/package-lock.json
!/README.md
!/.gitignore

# 3. CRITICAL: Explicitly ignore all secrets and local artifacts everywhere
# This overrides the directory allowance above for sensitive files.
**/.env
**/.env.*
**/.prod_key.md
**/.DS_Store
**/node_modules/
**/.next/
**/dist/
**/build/
**/*.log

# 4. Explicitly ignore all research, planning, and documentation folders
/refactor/
/docs/
/property/
/logo/
/scratch/
/scripts/
/docx_temp/
/VPD/
/GMS/
/stitch_sentiment_and_history_dashboard/
/svg-logos/
/gemini-code-*.json
/report.txt
/final_api_results.txt
/test_output.txt
